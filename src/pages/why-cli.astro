                font-size: 0.9rem;
                color: rgb(148 163 184);
                list-style: none;
                padding-left: 0;
                counter-reset: refs;
                line-height: 1.7;
            }
            .essay .references li {
                counter-increment: refs;
                padding-left: 2.6rem;
                text-indent: -2.6rem;
                margin-bottom: 0.75rem;
            }
            .essay .references li::before {
                content: "[" counter(refs) "]";
                display: inline-block;
                width: 2.2rem;
                margin-right: 0.4rem;
                color: rgb(255 139 106);
                font-variant-numeric: tabular-nums;
                font-weight: 600;
                text-indent: 0;
            }
            .essay .references em { font-style: italic; color: rgb(203 213 225); }
            html.light .essay .references { color: #64748b; }
            html.light .essay .references em { color: #0f172a; }

            html.light .essay h1,
            html.light .essay h2 {
                color: #0f172a;
            }
            html.light .essay p,
            html.light .essay li { color: #334155; }
            html.light .essay .lede { color: #1f2937; }
            html.light .essay .meta,
            html.light .essay .references { color: #64748b; }
