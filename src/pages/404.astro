---
import Layout from '../layouts/default.astro'
---
<Layout title="404 — doesitcli">
    <section class="max-w-screen-md mx-auto px-6 py-32 text-center space-y-6">
        <h1 class="text-5xl font-bold text-white">404</h1>
        <p class="text-gray-400">
            <span class="lang-en">This CLI isn't listed yet, or the page has moved.</span>
            <span class="lang-zh">这个 CLI 还没收录，或者页面已被移走。</span>
        </p>
        <a href="/" class="inline-block px-6 py-3 rounded-full bg-accent text-white no-underline">
            <span class="lang-en">Home</span>
            <span class="lang-zh">回首页</span>
        </a>
    </section>
</Layout>
