---
import '../../assets/css/tailwind.css'
import '@fontsource/inter/400.css'
import '@fontsource/inter/600.css'
import { STRINGS } from '../lib/i18n'

interface Props {
    title?: string
    description?: string
}

const {
    title = 'doesitcli — Desktop App CLI 目录',
    description = '每个 Desktop App 的 CLI，都在这里。Agent 友好，结构化索引，一步接入。',
} = Astro.props

const currentYear = new Date().getFullYear()
const stringsJson = JSON.stringify(STRINGS)
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <link rel="icon" href="/favicon.ico" />
        <title>{title}</title>
        <slot name="head" />
        <!-- Inline pre-paint script: avoid theme flash. Priority:
             1. user override in localStorage,
             2. OS prefers-color-scheme,
             3. light default (per product decision). -->
        <script is:inline>
            (function () {
                try {
                    let theme = localStorage.getItem('doesitcli.theme')
                    if (!theme) {
                        const m = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)')
                        theme = m && m.matches ? 'dark' : 'light'
                    }
                    if (theme === 'light') document.documentElement.classList.add('light')
                    // Default to English; user can override anywhere.
                    const l = localStorage.getItem('doesitcli.lang') || 'en'
                    document.documentElement.lang = l
                } catch (e) {}
            })()
        </script>
    </head>
    <body class="bg-gradient-to-bl from-dark to-darker bg-fixed text-gray-200">
        <header class="border-b border-white/10">
            <nav class="max-w-screen-xl mx-auto flex flex-wrap items-center gap-3 px-6 py-3">
                <a href="/" class="flex items-center text-base sm:text-lg font-semibold text-white no-underline hover:no-underline shrink-0">
                    <span>doesitcli<span class="text-accent">.com</span></span>
                </a>
                <a
                    href="/why-cli"
                    data-i18n="nav.whyCli"
                    class="text-xs sm:text-sm text-gray-300 hover:text-white no-underline hover:no-underline whitespace-nowrap"
                >Why we need CLI?</a>
                <div class="flex items-center gap-3 text-sm shrink-0 ml-auto">
                    <a href="/agent" data-i18n="nav.agent" class="hidden sm:inline">For Agents</a>
                    <button
                        id="theme-toggle"
                        class="px-2 py-1 rounded border border-white/10 hover:bg-white/5 text-base leading-none"
                        aria-label="切换主题"
                        title="Light / Dark"
                    >🌙</button>
                    <a
                        href="https://github.com/VIKI623/doesitcli"
                        rel="noopener"
                        target="_blank"
                        aria-label="GitHub"
                        title="GitHub"
                        class="hover:text-white text-gray-300 ml-1"
                    >
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39s1.97.13 2.89.39c2.21-1.5 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.85 1.18 3.1 0 4.42-2.69 5.4-5.26 5.68.41.36.78 1.06.78 2.14 0 1.55-.01 2.79-.01 3.17 0 .31.21.67.8.55C20.21 21.39 23.5 17.07 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
                        </svg>
                    </a>
                </div>
            </nav>
        </header>

        <main class="min-h-[calc(100vh-160px)]">
            <slot />
        </main>

        <footer class="border-t border-white/10 mt-24">
            <div class="max-w-screen-xl mx-auto px-6 py-10 text-sm text-gray-400">
                <p class="text-center">
                    <a href="https://github.com/VIKI623/doesitcli" rel="noopener" class="hover:text-white" data-i18n="footer.basedOn">开源项目</a>
                    &emsp;
                    <a href="/agent" class="hover:text-white" data-i18n="nav.agent">Agent 接入</a>
                    &emsp;
                    <span data-i18n="footer.friends">友情链接</span>:
                    <a href="https://github.com/jackwener/opencli" rel="noopener" target="_blank" class="hover:text-white">OpenCLI</a>
                    ｜
                    <a href="https://github.com/HKUDS/CLI-Anything" rel="noopener" target="_blank" class="hover:text-white">CLI-Anything</a>
                </p>
                <p class="mt-3 text-center" data-i18n="footer.tagline" data-i18n-vars={JSON.stringify({ year: currentYear })}>
                    © {currentYear} doesitcli.com — Desktop App CLI 目录 · Agent 友好
                </p>
            </div>
        </footer>

        <script is:inline define:vars={{ STRINGS_JSON: stringsJson }}>
            // ---------- Theme ----------
            // Match the pre-paint script: localStorage > OS preference > light default.
            const themeBtn = document.getElementById('theme-toggle')
            function applyTheme(theme) {
                document.documentElement.classList.toggle('light', theme === 'light')
                if (themeBtn) themeBtn.textContent = theme === 'light' ? '☀️' : '🌙'
            }
            function detectInitialTheme() {
                const stored = localStorage.getItem('doesitcli.theme')
                if (stored) return stored
                const m = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)')
                return m && m.matches ? 'dark' : 'light'
            }
            applyTheme(detectInitialTheme())
            themeBtn?.addEventListener('click', () => {
                const next = document.documentElement.classList.contains('light') ? 'dark' : 'light'
                localStorage.setItem('doesitcli.theme', next)
                applyTheme(next)
            })
            // Live-track OS theme changes when user has not made an explicit choice.
            window.matchMedia?.('(prefers-color-scheme: dark)')?.addEventListener?.('change', (e) => {
                if (!localStorage.getItem('doesitcli.theme')) applyTheme(e.matches ? 'dark' : 'light')
            })

            // ---------- i18n ----------
            const STRINGS = JSON.parse(STRINGS_JSON)
            function applyLang(lang) {
                document.documentElement.lang = lang
                document.querySelectorAll('[data-i18n]').forEach((el) => {
                    const key = el.getAttribute('data-i18n')
                    if (!key || !STRINGS[key]) return
                    let s = STRINGS[key][lang]
                    const varsAttr = el.getAttribute('data-i18n-vars')
                    if (varsAttr) {
                        try {
                            const vars = JSON.parse(varsAttr)
                            for (const [k, v] of Object.entries(vars)) s = s.split('{' + k + '}').join(String(v))
                        } catch (e) {}
                    }
                    el.textContent = s
                })
                document.querySelectorAll('[data-i18n-attr]').forEach((el) => {
                    // format: data-i18n-attr="placeholder:home.search.placeholder,title:foo.bar"
                    const spec = el.getAttribute('data-i18n-attr') || ''
                    for (const part of spec.split(',')) {
                        const [attr, key] = part.split(':')
                        if (attr && key && STRINGS[key]) el.setAttribute(attr, STRINGS[key][lang])
                    }
                })
            }
            const initLang = localStorage.getItem('doesitcli.lang') || 'en'
            applyLang(initLang)
            document.querySelectorAll('[data-lang-toggle]').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const next = document.documentElement.lang === 'en' ? 'zh' : 'en'
                    localStorage.setItem('doesitcli.lang', next)
                    applyLang(next)
                })
            })
        </script>
    </body>
</html>
